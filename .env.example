OPENAI_API_KEY=

# Clerk auth (deployment only). Leave empty locally — without these keys the
# app runs unauthenticated, which keeps `next dev` and the Electron shell
# working with zero setup.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

NEXT_PUBLIC_APP_NAME="Anchor"
# Optional: override the model used for catch-up generation.
OPENAI_MODEL=
# Optional: override the Realtime transcription model (default gpt-4o-mini-transcribe).
OPENAI_TRANSCRIBE_MODEL=
